{
  "$schema": "vscode://schemas/color-theme",
  "name": "Dark Midnight Pink Light",
  "type": "light",
  "colors": {
    // Editor Base & Canvas (Cozy Muted Rose-Milk, Low Glare)
    "editor.background": "#ebd8e2",
    "editor.foreground": "#1f1a1c",
    "editor.lineHighlightBackground": "#e2cbdb",
    "editor.lineHighlightBorder": "#00000000",
    "editor.selectionBackground": "#dca2c1",
    "editor.selectionForeground": "#1f1a1c",
    "editor.inactiveSelectionBackground": "#dca2c188",
    "editor.selectionHighlightBackground": "#d4a4bf88",
    "editor.wordHighlightBackground": "#d4a4bfaa",
    "editor.wordHighlightStrongBackground": "#ad386533",
    "editor.findMatchBackground": "#007a8c33",
    "editor.findMatchBorder": "#007a8c",
    "editor.findMatchHighlightBackground": "#007a8c1a",
    "editor.findMatchHighlightBorder": "#007a8c66",
    "editorBracketMatch.background": "#dca2c188",
    "editorBracketMatch.border": "#007a8c",
    "editorCursor.background": "#ebd8e2",
    "editorCursor.foreground": "#ad3865",
    "editorMultiCursor.primary.foreground": "#ad3865",
    "editorMultiCursor.secondary.foreground": "#ad3865",
    "editorLineNumber.foreground": "#9b7a8a",
    "editorLineNumber.activeForeground": "#ad3865",
    "editorGutter.background": "#ebd8e2",
    "editorError.foreground": "#a01b4c",
    "editorWarning.foreground": "#1b7a2b",
    "editorInfo.foreground": "#007a8c",

    // SideBar
    "sideBar.background": "#ebd8e2",
    "sideBar.foreground": "#2b1a22",
    "sideBar.border": "#d2b1c2",
    "sideBar.dropBackground": "#ebd8e2",
    "sideBarTitle.foreground": "#2b1a22",
    "sideBarTitle.background": "#ebd8e2",
    "sideBarTitle.border": "#d2b1c2",
    "sideBarSectionHeader.background": "#ebd8e2",
    "sideBarSectionHeader.foreground": "#2b1a22",
    "sideBarSectionHeader.border": "#d2b1c2",
    "sideBarActivityBarTop.border": "#ad3865",
    "sideBarStickyScroll.background": "#ebd8e2",
    "sideBarStickyScroll.border": "#d2b1c2",
    "sideBarStickyScroll.shadow": "#cc88aa",

    // Status Bar (Muted Rose-Plum)
    "statusBar.background": "#ad3865",
    "statusBar.foreground": "#ffffff",
    "statusBar.border": "#ad3865",
    "statusBar.noFolderBackground": "#ad3865",
    "statusBar.noFolderForeground": "#ffffff",
    "statusBar.noFolderBorder": "#ad3865",
    "statusBar.debuggingBackground": "#912a52",
    "statusBar.debuggingForeground": "#ffffff",
    "statusBar.debuggingBorder": "#912a52",
    "statusBarItem.hoverBackground": "#bf4977",
    "statusBarItem.hoverForeground": "#ffffff",
    "statusBarItem.activeBackground": "#802246",
    "statusBarItem.focusBorder": "#ffffff",
    "statusBar.focusBorder": "#ffffff",
    "statusBarItem.remoteBackground": "#912a52",
    "statusBarItem.remoteForeground": "#ffffff",
    "statusBarItem.remoteHoverBackground": "#802246",
    "statusBarItem.remoteHoverForeground": "#ffffff",
    "statusBarItem.errorBackground": "#a01b4c",
    "statusBarItem.errorForeground": "#ffffff",
    "statusBarItem.errorHoverBackground": "#ad3865",
    "statusBarItem.errorHoverForeground": "#ffffff",
    "statusBarItem.warningBackground": "#806000",
    "statusBarItem.warningForeground": "#ffffff",
    "statusBarItem.warningHoverBackground": "#ad3865",
    "statusBarItem.warningHoverForeground": "#ffffff",

    // Activity Bar
    "activityBar.background": "#ebd8e2",
    "activityBar.foreground": "#ad3865",
    "activityBar.inactiveForeground": "#7a6270",
    "activityBar.border": "#d2b1c2",
    "activityBarBadge.background": "#ad3865",
    "activityBarBadge.foreground": "#ffffff",
    "activityBar.activeBackground": "#ad38651a",
    "activityBar.activeBorder": "#007a8c",
    "activityBar.activeFocusBorder": "#007a8c",
    "activityBarTop.foreground": "#2b1a22",
    "activityBarTop.activeBorder": "#ad3865",
    "activityBarTop.inactiveForeground": "#7a6270",
    "activityBarTop.dropBorder": "#d2b1c2",

    // File Tree & Lists
    "list.activeSelectionBackground": "#ad386522",
    "list.activeSelectionForeground": "#802246",
    "list.activeSelectionIconForeground": "#802246",
    "list.dropBackground": "#ebd8e2",
    "list.focusBackground": "#e2cbdb",
    "list.focusForeground": "#2b1a22",
    "list.focusHighlightForeground": "#2b1a22",
    "list.highlightForeground": "#802246",
    "list.hoverBackground": "#dec2d3",
    "list.hoverForeground": "#802246",
    "list.focusOutline": "#ad3865",
    "list.focusAndSelectionOutline": "#ad3865",
    "list.inactiveSelectionBackground": "#e2cbdb",
    "list.inactiveSelectionForeground": "#2b1a22",
    "list.inactiveFocusBackground": "#e2cbdb",
    "list.inactiveFocusOutline": "#ad3865",
    "list.invalidItemForeground": "#c45400",
    "list.errorForeground": "#c41010",
    "list.warningForeground": "#806000",
    "listFilterWidget.background": "#ebd8e2",
    "listFilterWidget.outline": "#ad3865",
    "listFilterWidget.noMatchesOutline": "#ad3865",
    "listFilterWidget.shadow": "#d2b1c288",
    "list.filterMatchBackground": "#ebd8e2",
    "list.filterMatchBorder": "#d2b1c2",
    "tree.inactiveIndentGuidesStroke": "#d2b1c2",
    "tree.indentGuidesStroke": "#d2b1c2",

    // Tabs & Editor Groups
    "editorGroup.border": "#d2b1c2",
    "editorGroup.dropBackground": "#ad38651a",
    "editorGroup.emptyBackground": "#ebd8e2",
    "editorGroup.focusedEmptyBorder": "#ad3865",
    "editorGroupHeader.noTabsBackground": "#ebd8e2",
    "editorGroupHeader.tabsBackground": "#ebd8e2",
    "editorGroupHeader.tabsBorder": "#d2b1c2",
    "editorGroupHeader.border": "#d2b1c2",
    "tab.activeBackground": "#ebd8e2",
    "tab.activeForeground": "#2b1a22",
    "tab.activeBorderTop": "#ad3865",
    "tab.activeBorder": "#ad3865",
    "tab.border": "#d2b1c2",
    "tab.inactiveBackground": "#dfcad6",
    "tab.inactiveForeground": "#6e5261",
    "tab.hoverBackground": "#dec2d3",
    "tab.hoverForeground": "#2b1a22",
    "tab.unfocusedActiveBackground": "#ebd8e2",
    "tab.unfocusedActiveForeground": "#6e5261",
    "tab.unfocusedActiveBorderTop": "#d2b1c2",
    "tab.unfocusedInactiveBackground": "#dfcad6",
    "tab.unfocusedInactiveForeground": "#6e5261",

    // General UI Framework & Borders
    "focusBorder": "#ad3865",
    "contrastActiveBorder": "#a3456c",
    "contrastBorder": "#00000000",
    "foreground": "#2b1a22",
    "widget.border": "#d2b1c2",
    "selection.background": "#dca2c1",
    "descriptionForeground": "#802246",
    "errorForeground": "#2b1a22",
    "icon.foreground": "#007a8c",
    "sash.hoverBorder": "#a3456c",
    "window.activeBorder": "#ad3865",
    "window.inactiveBorder": "#d2b1c2",
    "textLink.activeForeground": "#007a8c",
    "textLink.foreground": "#2b1a22",
    "textSeparator.foreground": "#2b1a22",
    "textPreformat.background": "#e2cbdb",
    "textBlockQuote.background": "#e2cbdb",
    "textBlockQuote.border": "#d2b1c2",

    // Buttons & Controls
    "button.background": "#ad3865",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#802246",
    "button.border": "#d2b1c2",
    "button.separator": "#dca2c1",
    "button.secondaryForeground": "#2b1a22",
    "button.secondaryBackground": "#dfcad6",
    "button.secondaryHoverBackground": "#dec2d3",
    "button.secondaryBorder": "#d2b1c2",
    "checkbox.background": "#ebd8e2",
    "checkbox.foreground": "#2b1a22",
    "checkbox.border": "#d2b1c2",
    "dropdown.background": "#ebd8e2",
    "dropdown.foreground": "#2b1a22",
    "dropdown.border": "#d2b1c2",
    "dropdown.listBackground": "#ebd8e2",
    "input.background": "#ebd8e2",
    "input.foreground": "#2b1a22",
    "input.border": "#d2b1c2",
    "input.placeholderForeground": "#7a6270",

    // Scrollbar & Minimap
    "scrollbar.background": "#ebd8e2",
    "scrollbar.shadow": "#d2b1c288",
    "scrollbarSlider.activeBackground": "#ad386555",
    "scrollbarSlider.background": "#ad386533",
    "scrollbarSlider.hoverBackground": "#ad386544",
    "minimap.background": "#ebd8e2",
    "minimap.selectionHighlight": "#dec2d3aa",
    "minimapSlider.background": "#ad386522",
    "minimapSlider.hoverBackground": "#ad386544",

    // Panels, Terminals & Menus
    "panel.background": "#ebd8e2",
    "panel.border": "#d2b1c2",
    "panelTitle.activeForeground": "#ad3865",
    "panelTitle.activeBorder": "#ad3865",
    "panelTitle.inactiveForeground": "#6e5261",
    "panelTitle.border": "#d2b1c2",
    "terminal.background": "#ebd8e2",
    "terminal.foreground": "#1f1a1c",
    "terminal.border": "#d2b1c2",
    "terminalCursor.foreground": "#ad3865",
    "terminalCursor.background": "#ebd8e2",
    "titleBar.activeBackground": "#ebd8e2",
    "titleBar.activeForeground": "#2b1a22",
    "titleBar.inactiveBackground": "#ebd8e2",
    "titleBar.inactiveForeground": "#7a6270",
    "titleBar.border": "#d2b1c2",
    "menu.foreground": "#2b1a22",
    "menu.background": "#ebd8e2",
    "menu.selectionForeground": "#2b1a22",
    "menu.selectionBackground": "#dec2d3",
    "menu.selectionBorder": "#ad3865",
    "menu.separatorBackground": "#d2b1c2",
    "menu.border": "#d2b1c2",
    "commandCenter.foreground": "#2b1a22",
    "commandCenter.activeForeground": "#2b1a22",
    "commandCenter.background": "#ebd8e2",
    "commandCenter.activeBackground": "#dfcad6",
    "commandCenter.border": "#d2b1c2",

    // Bracket Colorization
    "editorBracketHighlight.foreground1": "#c41352",
    "editorBracketHighlight.foreground2": "#007a8c",
    "editorBracketHighlight.foreground3": "#7a119e",
    "editorBracketHighlight.foreground4": "#ad3865",
    "editorBracketHighlight.foreground5": "#c45400",
    "editorBracketHighlight.foreground6": "#2b1a22"
  },

  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#7a6270",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.logical.python"
      ],
      "settings": {
        "foreground": "#c41352",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.value",
        "string.tag",
        "meta.preprocessor.string"
      ],
      "settings": {
        "foreground": "#167024",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "support.constant.handlebars"
      ],
      "settings": {
        "foreground": "#00788a"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#1f1a1c"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "meta.return-type",
        "entity.name.tag.css",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#7a119e",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag",
        "meta.structure.dictionary.key.python",
        "support.type.property-name",
        "variable.css",
        "variable.scss"
      ],
      "settings": {
        "foreground": "#802246"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "keyword.operator",
        "support.function.git-rebase",
        "punctuation.definition.template-expression.begin.js",
        "punctuation.definition.template-expression.end.js",
        "punctuation.definition.template-expression.begin.ts",
        "punctuation.definition.template-expression.end.ts"
      ],
      "settings": {
        "foreground": "#00788a"
      }
    },
    {
      "scope": [
        "punctuation.bracket",
        "punctuation.definition.parameters",
        "punctuation.section.embedded",
        "meta.brace",
        "punctuation.separator.element",
        "punctuation.definition.arguments",
        "punctuation.definition.dict",
        "punctuation.definition.list",
        "punctuation.section.method",
        "punctuation.section.class",
        "punctuation.section.inner-class"
      ],
      "settings": {
        "foreground": "#ad3865"
      }
    },
    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#8f125a"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#c41010"
      }
    }
  ]
}